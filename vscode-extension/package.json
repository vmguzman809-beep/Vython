{
  "name": "nython-vscode",
  "displayName": "Ñython",
  "description": "Soporte básico para archivos Ñython.",
  "version": "0.1.0",
  "publisher": "nython",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vmguzman809-beep/Vython.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:nython",
    "onCommand:nython.runCurrentFile",
    "onCommand:nython.translateCurrentFile",
    "onCommand:nython.compileCurrentFile"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nython",
        "aliases": [
          "Ñython",
          "Nython"
        ],
        "extensions": [
          ".ny",
          ".nython"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nython",
        "scopeName": "source.nython",
        "path": "./syntaxes/nython.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "nython.runCurrentFile",
        "title": "Ñython: Ejecutar archivo actual"
      },
      {
        "command": "nython.translateCurrentFile",
        "title": "Ñython: Traducir archivo actual"
      },
      {
        "command": "nython.compileCurrentFile",
        "title": "Ñython: Compilar archivo actual"
      }
    ],
    "snippets": [
      {
        "language": "nython",
        "path": "./snippets/nython.json"
      }
    ]
  }
}
